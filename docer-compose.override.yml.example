# Anleitung:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   Dann Services anpassen und eintragen.
#   Die override.yml wird von Docker Compose automatisch geladen.

services:
  mein-repo:                                    # <- Service-Name (frei wählbar)
    <<: *runner-base
    environment:
      REPO_NAME: mein-repo                      # <- Runner-Name & Label im Workflow
      REPO_URL: https://github.com/USER/REPO    # <- Repo-URL
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - mein-repo:/github/workspace

      # Optional: App-Verzeichnis für Deploy-Jobs mounten
      # - /stacks/mein-repo:/opt/app

      # Optional: SSH-Deploy-Key für private Repos
      # - /home/pi/.ssh/github_deploy:/home/runner/.ssh/id_ed25519:ro

  # weiterer-repo:
  #   <<: *runner-base
  #   environment:
  #     REPO_NAME: weiterer-repo
  #     REPO_URL: https://github.com/USER/weiterer-repo
  #   volumes:
  #     - /var/run/docker.sock:/var/run/docker.sock
  #     - weiterer-repo:/github/workspace

volumes:
  mein-repo: